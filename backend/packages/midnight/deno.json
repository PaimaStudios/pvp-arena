{
    "name": "@pvp-arena-backend/midnight-contracts",
    "version": "0.3.0",
    "exports": {
        "./pvp": "./contract-pvp/src/index.ts"
    },
    "tasks": {
        "midnight-node:start": "MIDNIGHT_STORAGE_PASSWORD=yourpasswordmypassword CFG_PRESET=dev deno run -A --unstable-detect-cjs @paimaexample/npm-midnight-node --dev --rpc-port 9944 --state-pruning archive --blocks-pruning archive --public-addr /ip4/127.0.0.1 --unsafe-rpc-external",
        "midnight-node:wait": "wait-on tcp:9944",
        "midnight-indexer:start": "RUST_BACKTRACE=1 LEDGER_NETWORK_ID=\"Undeployed\" SUBSTRATE_NODE_WS_URL=\"ws://localhost:9944\" APP__INFRA__SECRET=$(openssl rand -hex 32 | tr 'a-f' 'A-F') FEATURES_WALLET_ENABLED=\"true\" APP__INFRA__NODE__URL=\"ws://localhost:9944\" deno run -A --unstable-detect-cjs @paimaexample/npm-midnight-indexer --binary --clean",
        "midnight-indexer:wait": "wait-on tcp:8088",
        "midnight-proof-server:start": "RUST_BACKTRACE=full SUBSTRATE_NODE_WS_URL=\"ws://localhost:9944\" deno run -A --unstable-detect-cjs @paimaexample/npm-midnight-proof-server",
        "midnight-proof-server:wait": "wait-on tcp:6300",
        "midnight-contract:clean": "rm -rf midnight-level-db contract-eip-20.undeployed.json contract-counter.undeployed.json",
        "midnight-contract:deploy": "deno task contract-pvp:deploy",
        "contract-pvp:deploy": "deno --unstable-detect-cjs -A contract-pvp-deploy.ts",
        "contract-pvp:deploy:dev": "MIDNIGHT_NETWORK_ID=undeployed deno --unstable-detect-cjs -A contract-pvp-deploy.ts",
        "contract-pvp:deploy:testnet": "MIDNIGHT_NETWORK_ID=preprod deno --unstable-detect-cjs -A contract-pvp-deploy.ts",
        "contract-pvp:deploy:mainnet": "MIDNIGHT_NETWORK_ID=mainnet deno --unstable-detect-cjs -A contract-pvp-deploy.ts",
        "contract-pvp:patch-frontend": "deno --unstable-detect-cjs -A contract-pvp-deploy.ts patch-frontend-env",
        "contract-pvp:patch-frontend:dev": "MIDNIGHT_NETWORK_ID=undeployed deno --unstable-detect-cjs -A contract-pvp-deploy.ts patch-frontend-env",
        "contract-pvp:patch-frontend:testnet": "MIDNIGHT_NETWORK_ID=preprod deno --unstable-detect-cjs -A contract-pvp-deploy.ts patch-frontend-env",
        "contract-pvp:patch-frontend:mainnet": "MIDNIGHT_NETWORK_ID=mainnet deno --unstable-detect-cjs -A contract-pvp-deploy.ts patch-frontend-env",
        "faucet": "deno run -A faucet.ts",
        "token-mint:compile": "cd contract-token-mint && compact compile +0.30.0 src/token-mint.compact ./src/managed/token_mint",
        "token-mint:deploy": "deno run -A --unstable-detect-cjs token-mint-deploy.ts"
    },
    "imports": {
        "@paimaexample/npm-midnight-node": "npm:@paimaexample/npm-midnight-node@0.10.13",
        "@paimaexample/npm-midnight-indexer": "npm:@paimaexample/npm-midnight-indexer@0.10.13",
        "@paimaexample/npm-midnight-proof-server": "npm:@paimaexample/npm-midnight-proof-server@0.10.13",
        "@std/path": "jsr:@std/path",
        "@std/fs": "jsr:@std/fs",
        "rxjs": "npm:rxjs@^7.8.2",
        "ws": "npm:ws",
        "@midnight-ntwrk/compact-runtime": "npm:@midnight-ntwrk/compact-runtime@0.15.0",
        "@midnight-ntwrk/wallet-sdk-address-format": "npm:@midnight-ntwrk/wallet-sdk-address-format@3.1.0",
        "@midnight-ntwrk/midnight-js-network-id": "npm:@midnight-ntwrk/midnight-js-network-id@4.0.2",
        "@midnight-ntwrk/midnight-js-types": "npm:@midnight-ntwrk/midnight-js-types@4.0.2",
        "@midnight-ntwrk/midnight-js-utils": "npm:@midnight-ntwrk/midnight-js-utils@4.0.2",
        "@midnight-ntwrk/midnight-js-contracts": "npm:@midnight-ntwrk/midnight-js-contracts@4.0.2",
        "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "npm:@midnight-ntwrk/midnight-js-indexer-public-data-provider@4.0.2",
        "@midnight-ntwrk/midnight-js-http-client-proof-provider": "npm:@midnight-ntwrk/midnight-js-http-client-proof-provider@4.0.2",
        "@midnight-ntwrk/midnight-js-node-zk-config-provider": "npm:@midnight-ntwrk/midnight-js-node-zk-config-provider@4.0.2",
        "@midnight-ntwrk/midnight-js-level-private-state-provider": "npm:@midnight-ntwrk/midnight-js-level-private-state-provider@4.0.2",
        "@midnight-ntwrk/wallet-sdk-abstractions": "npm:@midnight-ntwrk/wallet-sdk-abstractions@2.0.0",
        "@midnight-ntwrk/wallet-sdk-facade": "npm:@midnight-ntwrk/wallet-sdk-facade@3.0.0",
        "@midnight-ntwrk/wallet-sdk-hd": "npm:@midnight-ntwrk/wallet-sdk-hd@3.0.1",
        "@midnight-ntwrk/wallet-sdk-shielded": "npm:@midnight-ntwrk/wallet-sdk-shielded@2.1.0",
        "@midnight-ntwrk/wallet-sdk-dust-wallet": "npm:@midnight-ntwrk/wallet-sdk-dust-wallet@3.0.0",
        "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "npm:@midnight-ntwrk/wallet-sdk-unshielded-wallet@2.1.0",
        "@midnight-ntwrk/ledger-v8": "npm:@midnight-ntwrk/ledger-v8@8.0.3"
    }
}
