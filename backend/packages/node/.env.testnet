# Testnet environment (Midnight TestNet)
EFFECTSTREAM_ENV=testnet
NODE_ENV=production

# Midnight Network
MIDNIGHT_NETWORK_ID=preprod

# Proof server — runs locally even for deployed networks
MIDNIGHT_PROOF_SERVER_URL=http://127.0.0.1:6300

# Wallet — provide a funded wallet seed or mnemonic for testnet
# MIDNIGHT_WALLET_SEED=<your-testnet-wallet-seed>
# MIDNIGHT_WALLET_MNEMONIC=""

# Batcher
BATCHER_PORT=3334
