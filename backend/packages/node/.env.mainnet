# Mainnet environment (Midnight MainNet)
EFFECTSTREAM_ENV=mainnet
NODE_ENV=production

# Midnight Network
MIDNIGHT_NETWORK_ID=mainnet

# Proof server — runs locally even for deployed networks
MIDNIGHT_PROOF_SERVER_URL=http://127.0.0.1:6300

# Wallet — provide a funded wallet seed or mnemonic for mainnet
# MIDNIGHT_WALLET_SEED=<your-mainnet-wallet-seed>
# MIDNIGHT_WALLET_MNEMONIC=<your-mainnet-mnemonic>

# Batcher
BATCHER_PORT=3334
