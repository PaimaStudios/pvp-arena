{
    "workspace": [
      "./packages/**/*"
    ],
    "nodeModulesDir": "auto",
    "tasks": {
      "build:midnight": "deno task -f @pvp-arena-backend/midnight compact",
      "dev": "deno task -f @pvp-arena-backend/node dev",
      "testnet": "deno task -f @pvp-arena-backend/node testnet",
      "mainnet": "deno task -f @pvp-arena-backend/node mainnet",
      "start:frontend": "deno task -f @pvp-arena-backend/frontend dev",
      "check:dev": "deno task -f @pvp-arena-backend/node check:dev",
      "check:testnet": "deno task -f @pvp-arena-backend/node check:testnet",
      "check:mainnet": "deno task -f @pvp-arena-backend/node check:mainnet"
    },
    "imports": {
      "@paimaexample/tui": "jsr:@paimaexample/tui@0.10.5",
      "@paimaexample/midnight-contracts": "jsr:@paimaexample/midnight-contracts@0.10.5",
      "@paimaexample/evm-contracts": "jsr:@paimaexample/evm-contracts@0.10.5",
      "wait-on": "npm:wait-on@^9.0.4"
    },
    "lint": {
      "rules": {
        "exclude": [
          // needed for generators since you can't use the arrow function syntax
          "no-this-alias",
          // this is too strict to play well with effection
          "require-yield",
          // way too many typescript things that require using `any`
          "no-explicit-any",
          "ban-types", // `Function` and `{}` are occasionally useful
          "no-unused-vars", // maybe enable this at some point
          "no-slow-types" // would be nice to have, but this is a lot of work
        ]
      }
    },
    "allowScripts": ["npm:classic-level@3.0.0", "npm:cpu-features@0.0.10", "npm:esbuild@0.27.3", "npm:fsevents@2.3.3", "npm:msgpackr-extract@3.0.3", "npm:protobufjs@7.5.4", "npm:ssh2@1.17.0"]
  }