{
  "name": "pvp-phaser",
  "version": "0.1.0",
  "author": "IOG",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "http-server --port 0 ./dist",
    "dev": "vite --mode undeployed",
    "prepack": "yarn build",
    "build": "tsc && vite build --mode preview && cp -r ../contract/src/managed/pvp/keys ./dist/keys && cp -r ../contract/src/managed/pvp/zkir ./dist/zkir",
    "build-undeployed": "tsc && vite build --mode undeployed && cp -r ../contract/src/managed/pvp/keys ./dist/keys && cp -r ../contract/src/managed/pvp/zkir ./dist/zkir",
    "preview": "vite preview",
    "lint": "eslint ./src",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@midnight-ntwrk/pvp-api": "workspace:*",
    "@midnight-ntwrk/pvp-contract": "workspace:*",
    "@paima/midnight-wasm-prover": "^0.1.0-alpha4",
    "@vitejs/plugin-react": "^4.3.4",
    "buffer": "^6.0.3",
    "crypto-browserify": "3.12.1",
    "phaser": "3.87.0",
    "phaser3-rex-plugins": "1.80.12"
  },
  "devDependencies": {
    "@originjs/vite-plugin-commonjs": "^1.0.3",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^8.52.0",
    "eslint-config-standard-with-typescript": "^39.1.1",
    "eslint-plugin-react": "^7.33.2",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-top-level-await": "1.6.0",
    "vite-plugin-wasm": "^3.5.0"
  }
}
